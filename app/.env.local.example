# Shopify Storefront API
# 1. Create a Shopify store at shopify.com
# 2. Go to Settings > Apps > Develop apps > Create an app
# 3. Configure Storefront API scopes:
#    - unauthenticated_read_product_listings
#    - unauthenticated_write_checkouts
#    - unauthenticated_read_checkouts
#    - unauthenticated_read_product_tags
# 4. Install the app and copy the Storefront access token

NEXT_PUBLIC_SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
NEXT_PUBLIC_SHOPIFY_STOREFRONT_TOKEN=your-storefront-access-token
